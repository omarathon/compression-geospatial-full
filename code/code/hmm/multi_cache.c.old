typedef struct {
    QuadtreeNode* nodes[MAX_CACHE_SIZE]; // Array of pointers to cached nodes
    int count;                          // Number of nodes currently in the cache
} QuadtreeCache;

QuadtreeCache cache = {{NULL}, 0};  // Initialize an empty cache

bool isNodeInCache(QuadtreeNode* node) {
    for (int i = 0; i < cache.count; i++) {
        if (cache.nodes[i] == node) {
            return true;
        }
    }
    return false;
}

void addToCache(QuadtreeNode* node) {
    if (cache.count < MAX_CACHE_SIZE) {
        cache.nodes[cache.count++] = node;
    } else {
        // Cache is full, consider a replacement strategy
    }
}

void removeFromCache(QuadtreeNode* node) {
    for (int i = 0; i < cache.count; i++) {
        if (cache.nodes[i] == node) {
            // Shift the remaining elements
            for (int j = i; j < cache.count - 1; j++) {
                cache.nodes[j] = cache.nodes[j + 1];
            }
            cache.count--;
            return;
        }
    }
}

// Helper function to calculate the square of a number
static inline int square(int x) {
    return x * x;
}

bool overlapsCircle(int nodeX, int nodeY, int nodeWidth, int nodeHeight, int centerX, int centerY, int radius) {
    // Find the closest point in the rectangle to the circle's center
    int closestX = fmax(nodeX, fmin(centerX, nodeX + nodeWidth));
    int closestY = fmax(nodeY, fmin(centerY, nodeY + nodeHeight));

    // Calculate the distance from this point to the circle's center
    int distanceSquared = square(closestX - centerX) + square(closestY - centerY);

    // Check if the distance is less than or equal to the radius squared
    return distanceSquared <= square(radius);
}

void readWindow(QuadtreeNode* root, int x, int y, int R) {
    // Remove non-overlapping nodes from the cache
    for (int i = 0; i < cache.count; i++) {
        if (!overlapsCircle(cache.nodes[i]->x, cache.nodes[i]->y, cache.nodes[i]->width, cache.nodes[i]->height, x, y, R)) {
            // Un-cache the uncompressed data
            if (cache.nodes[i]->compress) {
                free(cache.nodes[i]->uncompressedData);
            }
            removeFromCache(cache.nodes[i]);
            i--;  // Adjust the index after removal
        }
    }

    // Process the quadtree nodes
    processQuadtreeForWindow(root, x, y, R);
}

void processQuadtreeForWindow(QuadtreeNode* node, int centerX, int centerY, int radius) {
    if (node == NULL) {
        return;
    }

    // Check if the node overlaps with the circle
    if (overlapsCircle(node->x, node->y, node->width, node->height, centerX, centerY, radius)) {
        if (isLeafNode(node) && !isNodeInCache(node)) {
            // Decompress the node's data and add it to the cache
            if (node->uncompressedData == NULL) {
                decompressData(node->compressedData, node->uncompressedSize);
            }
            addToCache(node);
        } else {
            // Recursively process children
            for (int i = 0; i < 4; i++) {
                processQuadtreeForWindow(node->children[i], centerX, centerY, radius);
            }
        }
    }
}